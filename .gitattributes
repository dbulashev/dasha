# Generated code: treat as binary (`binary` = -diff -merge -text) so GitHub renders
# it as "Binary file not shown" and excludes it from the PR's +/- line count, and
# collapse in review + drop from language stats (linguist-generated). `-diff` alone
# still counts on GitHub; only the binary/-text treatment removes it. Keep paths
# specific — src/api/customFetch.ts is hand-written.
/backend/gen/** binary linguist-generated=true
/frontend/src/api/gen/** binary linguist-generated=true
/frontend/src/api/models/** binary linguist-generated=true
