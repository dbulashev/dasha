FROM --platform=$BUILDPLATFORM golang:1.26.5-alpine AS builder
ARG TARGETOS TARGETARCH
ARG BUILD_NUMBER=dev
ARG BUILD_DATE=unknown
WORKDIR /app
COPY backend/go.mod backend/go.sum ./
RUN go mod download
COPY backend/ .
RUN CGO_ENABLED=0 GOOS=$TARGETOS GOARCH=$TARGETARCH go build \
    -ldflags="-s -w -X github.com/dbulashev/dasha/internal/version.buildNumber=$BUILD_NUMBER -X github.com/dbulashev/dasha/internal/version.buildDate=$BUILD_DATE" \
    -o /dasha-mcp ./cmd/dasha-mcp

FROM alpine:3.24
RUN apk add --no-cache ca-certificates && \
    addgroup -S dasha && adduser -S -G dasha -u 1000 dasha
COPY --from=builder /dasha-mcp /usr/local/bin/dasha-mcp
USER dasha
# HTTP/SSE transport port (only used with --http; stdio mode needs no port)
EXPOSE 8765
ENTRYPOINT ["dasha-mcp"]
